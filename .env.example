# ── Database ──────────────────────────────────────────
# PostgreSQL connection string used by Drizzle.
DATABASE_URL=postgresql://user:password@localhost:5432/mia_inventory

# ── Auth (Better Auth) ────────────────────────────────
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# ── Superadmin (bootstrap account, not stored in DB) ──
SUPERADMIN_NIK=ADM000
SUPERADMIN_PASSWORD=replace-with-a-strong-password
